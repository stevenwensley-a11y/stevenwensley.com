{# Shared <head> block.
   Variables expected from frontmatter:
     - title:           required, page <title>
     - description:     required, meta description (50–160 chars)
     - ogTitle:         optional override for og:title (defaults to title)
     - ogDescription:   optional override for og:description
     - ogType:          'website' | 'article' (default 'website')
     - twitterTitle:    optional override
     - twitterDescription: optional override
     - canonical:       full URL of canonical
     - permalink:       Eleventy permalink, used for og:url default
     - hreflang:        array of { lang: 'en'|'da'|'x-default', href }
     - jsonLd:          optional raw object for application/ld+json
#}
<!-- Google Analytics -->
<script async src="https://www.googletagmanager.com/gtag/js?id={{ site.ga4Id }}"></script>
<script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','{{ site.ga4Id }}');</script>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="robots" content="index, follow">
<meta name="view-transition" content="same-origin">

<title>{{ title }} | {{ site.shortName }}</title>
<meta name="description" content="{{ description }}">

<!-- Open Graph -->
<meta property="og:type" content="{{ ogType or 'website' }}">
<meta property="og:url" content="{{ canonical or (site.url + permalink) }}">
<meta property="og:title" content="{{ ogTitle or title }}">
<meta property="og:description" content="{{ ogDescription or description }}">
<meta property="og:image" content="{{ site.ogImage }}">
<meta property="og:locale" content="{{ ogLocale or site.locale }}">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ twitterTitle or ogTitle or title }}">
<meta name="twitter:description" content="{{ twitterDescription or ogDescription or description }}">
<meta name="twitter:image" content="{{ site.ogImage }}">

<link rel="canonical" href="{{ canonical or (site.url + permalink) }}">
{% for alt in hreflang %}<link rel="alternate" hreflang="{{ alt.lang }}" href="{{ alt.href }}">
{% endfor %}

<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='4' fill='%230a0a0f'/%3E%3Ctext x='50%25' y='54%25' dominant-baseline='middle' text-anchor='middle' font-family='Georgia,serif' font-weight='700' font-size='16' fill='%23c9a96e'%3ESSW%3C/text%3E%3C/svg%3E">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">

{%- if jsonLd %}
<!-- Structured data -->
<script type="application/ld+json">{{ jsonLd | dump | safe }}</script>
{%- endif %}

{# BreadcrumbList JSON-LD — emitted automatically when an article sets
   breadcrumbs in frontmatter (or when layout=article.njk auto-builds it
   from /insights → article). Helps Google render breadcrumb trails in
   search results. #}
{%- if breadcrumbs %}
<script type="application/ld+json">{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {%- for b in breadcrumbs %}
    { "@type": "ListItem", "position": {{ loop.index }}, "name": {{ b.name | dump | safe }}, "item": {{ b.url | dump | safe }} }{% if not loop.last %},{% endif %}
    {%- endfor %}
  ]
}</script>
{%- endif %}

{# Atom + JSON Feed discovery — let feed readers and browsers
   auto-detect /feed.xml and /feed.json. #}
<link rel="alternate" type="application/atom+xml" title="{{ site.shortName }} — Insights" href="{{ site.url }}/feed.xml">
<link rel="alternate" type="application/feed+json" title="{{ site.shortName }} — Insights" href="{{ site.url }}/feed.json">

{# LinkedIn Insight Tag — disabled by default. To activate, set
   `site.linkedinInsightId` in /src/_data/site.js to your LinkedIn
   Campaign Manager partner ID (a 7-digit number from
   linkedin.com/campaignmanager → Account Assets → Insight Tag).
   This enables conversion tracking and audience retargeting for any
   future LinkedIn Ads campaigns. Without an ID, the snippet is omitted
   so there is zero performance impact today. #}
{%- if site.linkedinInsightId %}
<script type="text/javascript">
_linkedin_partner_id = "{{ site.linkedinInsightId }}";
window._linkedin_data_partner_ids = window._linkedin_data_partner_ids || [];
window._linkedin_data_partner_ids.push(_linkedin_partner_id);
</script><script type="text/javascript">
(function(l) {if (!l){window.lintrk = function(a,b){window.lintrk.q.push([a,b])};window.lintrk.q=[]}var s = document.getElementsByTagName("script")[0];var b = document.createElement("script");b.type = "text/javascript";b.async = true;b.src = "https://snap.licdn.com/li.lms-analytics/insight.min.js";s.parentNode.insertBefore(b, s);})(window.lintrk);
</script>
<noscript><img height="1" width="1" style="display:none;" alt="" src="https://px.ads.linkedin.com/collect/?pid={{ site.linkedinInsightId }}&fmt=gif" /></noscript>
{%- endif %}
