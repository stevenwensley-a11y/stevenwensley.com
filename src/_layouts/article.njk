{# Article layout for /insights/* posts.

   Frontmatter contract (per article):
     title:           string, h1 + window title
     description:     string, meta + og:description
     ogTitle:         string, optional override of og:title (defaults to title)
     ogDescription:   string, optional
     twitterTitle:    string, optional
     twitterDescription: string, optional
     slug:            string, used for permalink (no extension)
     permalink:       string, /insights/<slug>.html (set per article)
     datePublished:   ISO date 2026-MM-DD
     dateModified:    ISO date
     tag:             string, e.g. "AI Governance"
     displayDate:     string, e.g. "3 Mar 2026"
     readTime:        string, e.g. "7 min read"
     lead:            string, the dek paragraph after the h1
     linkedinUrl:     string, link to LinkedIn post (optional, defaults to author)
     related:         array of { slug, title, description }, exactly 2

   Body content is the rendered Markdown / Nunjucks below the frontmatter.
#}
<!DOCTYPE html>
<html lang="en">
<head>
  {% include "head.njk" %}
  <style>
    {% include "article-styles.css" %}
  </style>
  {% include "skip-link.njk" %}
</head>
<body>
  <a class="skip-link" href="#main">Skip to main content</a>
  {% include "nav.njk" %}
  <main id="main" tabindex="-1">
    <article>
      <div class="article-header">
        <a href="../insights.html" class="back-link">← All Insights</a>
        <div class="article-meta">
          <span class="tag">{{ tag }}</span>
          <span>{{ displayDate }}</span>
          <span>{{ readTime }}</span>
        </div>
        <h1>{{ title }}</h1>
        <p class="article-lead">{{ lead }}</p>
      </div>

      <div class="linkedin-source">
        <a href="{{ linkedinUrl or site.author.linkedin }}" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          Originally published on LinkedIn
        </a>
      </div>

      <div class="article-body">
        {{ content | safe }}
      </div>
    </article>

    <div class="related">
      <h3>Related Articles</h3>
      <div class="related-list">
        {%- for r in related %}
        <a href="{{ r.slug }}.html" class="related-item">
          <h4>{{ r.title }}</h4>
          <p>{{ r.description }}</p>
        </a>
        {%- endfor %}
      </div>
    </div>

    {%- if cta %}
    <div class="cta-section">
      <h3>{{ cta.heading }}</h3>
      <p>{{ cta.body | safe }}</p>
      <div class="cta-buttons">
        {%- for btn in cta.buttons %}
        <a href="{{ btn.href }}" class="{{ btn.class }}" onclick="{{ btn.onclick | safe }}">{{ btn.label | safe }}</a>
        {%- endfor %}
      </div>
      {%- if cta.divider %}
      <p class="cta-divider">{{ cta.divider | safe }}</p>
      {%- endif %}
    </div>
    {%- endif %}
  </main>
  {% include "footer.njk" %}
</body>
</html>
